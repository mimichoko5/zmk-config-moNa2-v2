/ {
  zip_mouse_gesture_l8: zip_mouse_gesture_l8 {
    compatible = "zmk,input-processor-mouse-gesture";
    #input-processor-cells = <0>;
    enable-eager-mode;
    stroke-size = <5>;
    movement-threshold = <6>;
    idle-timeout-ms = <100>;
    gesture-cooldown-ms = <120>;

    col_insert { pattern = <GESTURE_UP>;    bindings = <&kp LC(LS(EQUAL))>; }; // 列追加
    col_delete { pattern = <GESTURE_DOWN>;  bindings = <&kp LC(MINUS)>;     }; // 列削除
    row_delete { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(MINUS)>;     }; // 行削除
    row_insert { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(LS(EQUAL))>; }; // 行追加
  };
};
