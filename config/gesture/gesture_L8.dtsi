/ {
  zip_mouse_gesture_l8: zip_mouse_gesture_l8 {
    compatible = "zmk,input-processor-mouse-gesture";
    #input-processor-cells = <0>;
    enable-eager-mode;
    stroke-size = <5>;
    movement-threshold = <6>;
    idle-timeout-ms = <100>;
    gesture-cooldown-ms = <120>;

    col_insert { pattern = <GESTURE_UP>;    bindings = <&col_insert_macro>; }; // еҲ—е…ЁйҒёжҠһвҶ’еҲ—иҝҪеҠ 
    col_delete { pattern = <GESTURE_DOWN>;  bindings = <&col_delete_macro>; }; // еҲ—е…ЁйҒёжҠһвҶ’еҲ—еүҠйҷӨ
    paste      { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(V)>; };         // еҸігӮ№гӮҜгғӯгғјгғ«вҶ’иІјгӮҠд»ҳгҒ‘
    copy       { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(C)>; };         // е·ҰгӮ№гӮҜгғӯгғјгғ«вҶ’гӮігғ”гғј
  };
};
