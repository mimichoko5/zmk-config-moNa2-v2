/ {
  zip_mouse_gesture_l8: zip_mouse_gesture_l8 {
    compatible = "zmk,input-processor-mouse-gesture";
    #input-processor-cells = <0>;
    enable-eager-mode;
    stroke-size = <5>;
    movement-threshold = <6>;
    idle-timeout-ms = <100>;
    gesture-cooldown-ms = <120>;

    // 上下(GESTURE_UP/DOWN)は何もしない(ノード未定義=無効)
    paste { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(V)>; }; // 右スクロール→貼り付け
    copy  { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(C)>; }; // 左スクロール→コピー
  };
};
